  <property name="styleSheet">
   <string notr="true">/* Fondo general del Dialogo */
QDialog {
    background-color: #f4f6f9;
}

/* El contenedor central si usas un QWidget adentro */
QWidget {
    font-family: &quot;Arial&quot;;
}

/* Título Principal */
QLabel {
    color: #2c3e50;
    font-size: 16px;
    font-weight: bold;
}

/* Estilo limpio para tus 4 botones de opciones */
QPushButton {
    font-family: &quot;Arial&quot;;
    font-size: 14px;
    font-weight: bold;
    color: #1e3a5f;
    background-color: #e3f2fd;
    border: 1px solid #bdc3c7;
    border-radius: 8px;
    padding: 12px;
}

/* Efecto cuando pasas el mouse por encima */
QPushButton:hover {
    background-color: #bbdefb;
    border: 1px solid #3498db;
    color: #0d47a1;
}

/* Efecto cuando lo presionas */
QPushButton:pressed {
    background-color: #1e88e5;
    color: #ffffff;
}</string>
